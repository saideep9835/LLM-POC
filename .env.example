# LLM Provider Configuration
LLM_PROVIDER=openai

# API Keys (Add your actual keys here)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Configuration
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_TOKENS=1024

# Azure AI Language (Sentiment Analysis)
AZURE_LANGUAGE_ENDPOINT=https://your-language-resource-name.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=your_azure_language_key_here

# Azure AI Document Intelligence (PDF/DOCX text extraction)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_document_intelligence_key_here

# Azure AI Speech (Audio transcription)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
# Optional alternative to region: full Speech endpoint URL
# Example: https://your-speech-resource.cognitiveservices.azure.com/
AZURE_SPEECH_ENDPOINT=https://your-speech-resource.cognitiveservices.azure.com/

# Azure AI Video Indexer (Video sentiment analysis)
# Account ID: vi.microsoft.com -> Settings -> Account
# API Key: api-portal.videoindexer.ai -> Profile -> Primary key
# Location: "trial" for free tier, or your Azure region e.g. "eastus"
AZURE_VIDEO_INDEXER_ACCOUNT_ID=your_account_id_here
AZURE_VIDEO_INDEXER_LOCATION=trial
AZURE_VIDEO_INDEXER_API_KEY=your_api_key_here
